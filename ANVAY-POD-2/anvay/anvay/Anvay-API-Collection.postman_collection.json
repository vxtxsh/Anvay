      "item": [
        {
          "name": "Get All Clubs by Institution",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/clubs/institution/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "clubs",
                "institution",
                "1"
              ]
            },
            "description": "Retrieve dashboard data for all clubs in an institution (US16P2_12)\n\nReturns:\n- clubId\n- clubName\n- type (category)\n- membersCount\n- joinRequestsCount\n- leadershipAppsCount\n- createdDate"
